# ──────────────────────────────────────────────
# SelfDiary — EditorConfig
# ──────────────────────────────────────────────
# Consistent coding style across editors and IDEs.
# Supported by VS Code, JetBrains, Vim, and others.
# See: https://editorconfig.org
# ──────────────────────────────────────────────

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.sh]
indent_size = 2
end_of_line = lf

[Makefile]
indent_style = tab

[docker-compose.yml]
indent_size = 2
