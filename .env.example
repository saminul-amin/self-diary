# ──────────────────────────────────────────────
# SelfDiary — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All values below are safe defaults for local development.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────

# ─── PostgreSQL ───
POSTGRES_USER=selfdiary
POSTGRES_PASSWORD=selfdiary_dev
POSTGRES_DB=selfdiary
POSTGRES_PORT=5432

# ─── FastAPI Backend ───
API_PORT=8000
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# ─── JWT Authentication ───
# IMPORTANT: Generate a strong secret for production.
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── S3 / Minio (Object Storage) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=selfdiary-attachments

# ─── Next.js Web Client ───
NEXT_PUBLIC_API_URL=http://localhost:8000/v1

# ─── React Native Mobile Client ───
# Set to your machine's LAN IP for device testing
EXPO_PUBLIC_API_URL=http://localhost:8000/v1
